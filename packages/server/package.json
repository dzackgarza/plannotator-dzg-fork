{
  "name": "@plannotator/server",
  "version": "0.12.0",
  "private": true,
  "description": "Shared server implementation for Plannotator plugins",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./review": "./review.ts",
    "./annotate": "./annotate.ts",
    "./remote": "./remote/index.ts",
    "./port": "./port.ts",
    "./browser": "./browser.ts",
    "./state": "./state.ts",
    "./storage": "./storage.ts",
    "./git": "./git.ts",
    "./repo": "./repo.ts",
    "./resolve-file": "./resolve-file.ts",
    "./sessions": "./sessions.ts",
    "./project": "./project.ts"
  },
  "files": [
    "*.ts"
  ],
  "dependencies": {
    "@plannotator/shared": "workspace:*"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
